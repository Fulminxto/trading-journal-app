generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  FOUNDER
  ADMIN
  MEMBER
  VIEWER
}

enum SyncOperationStatus {
  STARTED
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
  ABANDONED
}

enum SyncOperationItemStatus {
  PROCESSING
  CREATED
  UPDATED
  SKIPPED
  FAILED
}

enum SyncOperationEffectStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id           String @id @default(cuid())
  username     String @unique
  passwordHash String

  role String @default("MEMBER")

  canCreatePersonalAccounts Boolean @default(true)
  canCreateSharedAccounts   Boolean @default(false)

  canArchiveOwnAccounts Boolean @default(true)
  canDeleteOwnAccounts  Boolean @default(false)

  canUseCopilot Boolean @default(true)

  canViewAnalytics Boolean @default(true)
  canViewReports   Boolean @default(true)

  canManageUsers  Boolean @default(false)
  canManageSystem Boolean @default(false)

  status   String    @default("ACTIVE")
  frozenAt DateTime?

  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  lastSeenAt     DateTime?
  lastLoginAt    DateTime?
  lastActivityAt DateTime?

  loginCount Int @default(0)

  activityLogs  ActivityLog[]
  notifications Notification[]

  name          String?
  image         String?
  bio           String?
  workspaceName String?

  tradingStyle   String?
  favoriteMarket String?
  timezone       String?

  preferredSession String?
  riskPerTrade     Float?
  preferredBroker  String?
  setupStyle       String?

  defaultCurrency String @default("USD")

  appLanguage     String @default("en")
  themePreference String @default("dark")
  accentColor     String @default("green")
  appIconVariant  String @default("classic")

  compactMode      Boolean @default(false)
  performanceBlur  Boolean @default(false)
  email            String? @unique
  twoFactorEnabled Boolean @default(false)

  emailNotifications Boolean @default(false)

  reviewReminders      Boolean @default(true)
  sessionLockAlerts    Boolean @default(true)
  dailyTradingReminder Boolean @default(false)

  notificationsEnabled  Boolean @default(true)
  notifyTradeActivity   Boolean @default(true)
  notifyAccountActivity Boolean @default(true)
  notifyPlatformUpdates Boolean @default(true)
  notifySupport         Boolean @default(true)

  pushNotificationsEnabled Boolean            @default(false)
  pushSubscriptions        PushSubscription[]

  twoFactorCodes TwoFactorCode[]

  memberships             AccountMember[]
  sentInvites             AccountInvite[]  @relation("InvitedBy")
  receivedInvites         AccountInvite[]  @relation("InvitedUser")
  createdTrades           Trade[]
  createdSessions         TradingSession[]
  initiatedSyncOperations SyncOperation[]

  createdAccounts TradingAccount[] @relation("CreatedTradingAccounts")

  supportTickets SupportTicket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TradingAccount {
  id     String        @id @default(cuid())
  name   String
  type   AccountType
  status AccountStatus @default(ACTIVE)

  initialBalance Float
  currency       String @default("USD")

  createdById String?
  createdBy   User?   @relation("CreatedTradingAccounts", fields: [createdById], references: [id], onDelete: SetNull)

  broker        String?
  phase         String?
  profitTarget  Float?
  maxDrawdown   Float?
  dailyDrawdown Float?

  integrationMode String  @default("manual")
  autoSyncEnabled Boolean @default(false)

  mt5Enabled      Boolean @default(false)
  mt5AccountLogin String?
  mt5ServerName   String?

  brokerSyncEnabled Boolean @default(false)
  brokerProvider    String?
  brokerAccountId   String?

  syncStatus   String    @default("inactive")
  lastSyncedAt DateTime?

  members        AccountMember[]
  invites        AccountInvite[]
  trades         Trade[]
  sessions       TradingSession[]
  goals          TradingGoal[]
  strategies     Strategy[]
  syncOperations SyncOperation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs ActivityLog[]

  copilotMessages    CopilotMessage[]
  copilotPatterns    CopilotPattern[]
  copilotReviewNotes CopilotReviewNote[]
  copilotMemories    CopilotMemory[]
}

model AccountMember {
  id               String     @id @default(cuid())
  userId           String
  tradingAccountId String
  role             MemberRole @default(MEMBER)

  canCreateTrades Boolean @default(true)
  canEditTrades   Boolean @default(true)
  canDeleteTrades Boolean @default(true)

  canViewAnalytics Boolean @default(true)
  canViewReports   Boolean @default(true)
  canViewCopilot   Boolean @default(true)
  canViewMembers   Boolean @default(true)

  // Reserved for future feature: member/role management by MANAGER. Do not remove.
  canManageMembers Boolean @default(false)
  canManageRoles   Boolean @default(false)
  canManageAccount Boolean @default(false)

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradingAccount TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, tradingAccountId])
}

model AccountInvite {
  id               String     @id @default(cuid())
  tradingAccountId String
  invitedUserId    String
  invitedByUserId  String
  role             MemberRole @default(MEMBER)
  createdAt        DateTime   @default(now())

  tradingAccount TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)
  invitedUser    User           @relation("InvitedUser", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy      User           @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([invitedUserId, tradingAccountId])
  @@index([tradingAccountId])
  @@index([invitedUserId])
}

model Trade {
  id Int @id @default(autoincrement())

  tradingAccountId String
  createdById      String

  tradingAccount TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)
  createdBy      User           @relation(fields: [createdById], references: [id], onDelete: Cascade)

  openDate        DateTime
  openTime        String?
  reason          String?
  strategy        String?
  strategyId      String?
  strategyRef     Strategy? @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  symbol          String
  direction       String
  amount          Float?
  openingPrice    Float?
  stopLoss        Float?
  takeProfit      Float?
  riskReward      Float?
  closeDate       DateTime?
  closingPrice    Float?
  outcome         String?
  resultUsd       Float?
  resultPercent   Float?
  equity          Float?
  equityPeak      Float?
  drawdownPercent Float?
  notes           String?

  session         String?
  emotionalState  String?
  setupQuality    Int?
  executionRating Int?
  confidence      Int?
  mistakes        String?
  lessonsLearned  String?

  source      String  @default("manual")
  syncStatus  String  @default("manual")
  needsReview Boolean @default(false)

  externalTradeId   String?
  externalAccountId String?
  externalOrderId   String?

  platform   String?
  brokerName String?

  commission Float?
  swap       Float?
  fees       Float?

  importedAt    DateTime?
  rawImportData Json?

  syncOperationItems SyncOperationItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tradingAccountId, externalTradeId])
  @@index([tradingAccountId])
  @@index([strategyId])
  @@index([source])
  @@index([syncStatus])
  @@index([needsReview])
  @@index([externalTradeId])
}

model SyncOperation {
  id String @id @default(cuid())

  accountId String
  account   TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  actorUserId String?
  actorUser   User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  source          String
  trigger         String
  externalBatchId String

  status SyncOperationStatus @default(STARTED)

  items   SyncOperationItem[]
  effects SyncOperationEffect[]

  totalCount    Int?
  importedCount Int  @default(0)
  updatedCount  Int  @default(0)
  skippedCount  Int  @default(0)
  failedCount   Int  @default(0)

  startedAt   DateTime  @default(now())
  lastItemAt  DateTime?
  completedAt DateTime?
  durationMs  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, source, externalBatchId])
  @@index([accountId, startedAt])
  @@index([actorUserId, startedAt])
  @@index([status, startedAt])
}

model SyncOperationItem {
  id String @id @default(cuid())

  operationId String
  operation   SyncOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  itemKey     String
  payloadHash String

  status SyncOperationItemStatus @default(PROCESSING)

  tradeId Int?
  trade   Trade? @relation(fields: [tradeId], references: [id], onDelete: SetNull)

  needsReview   Boolean?
  syncStatus    String?
  changedFields String[] @default([])

  safeErrorCode String?
  httpStatus    Int?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([operationId, itemKey])
  @@index([operationId, status])
  @@index([tradeId])
}

model SyncOperationEffect {
  id String @id @default(cuid())

  operationId String
  operation   SyncOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  effectKey String
  status    SyncOperationEffectStatus @default(PENDING)

  attemptCount  Int     @default(0)
  safeErrorCode String?

  notificationId String?       @unique
  notification   Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)

  startedAt     DateTime?
  lastAttemptAt DateTime?
  completedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([operationId, effectKey])
  @@index([status, updatedAt])
  @@index([operationId, status])
}

model Strategy {
  id               String   @id @default(cuid())
  tradingAccountId String
  name             String
  description      String?
  color            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tradingAccount TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)
  trades         Trade[]

  @@unique([tradingAccountId, name])
  @@index([tradingAccountId])
}

model CopilotMessage {
  id String @id @default(cuid())

  tradingAccountId String
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  role    String
  content String

  createdAt DateTime @default(now())
}

model CopilotPattern {
  id String @id @default(cuid())

  tradingAccountId String
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  type        String
  title       String
  description String
  severity    String

  occurrences Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CopilotMemory {
  id String @id @default(cuid())

  tradingAccountId String
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  memoryType  String
  title       String
  description String

  severity String
  score    Int

  firstDetectedAt DateTime @default(now())
  lastDetectedAt  DateTime @updatedAt

  createdAt DateTime @default(now())

  @@index([tradingAccountId])
}

model SupportTicket {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String
  subject String
  message String

  status   String @default("open")
  priority String @default("normal")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminNote  String?
  resolvedAt DateTime?

  @@index([userId])
}

model ReleaseNote {
  id String @id @default(cuid())

  title    String
  content  String
  type     String @default("update")
  priority String @default("normal")

  published Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceMode {
  id String @id @default(cuid())

  enabled Boolean @default(false)

  title   String
  message String

  type String @default("warning")

  startAt       DateTime?
  expectedEndAt DateTime?

  blockLogin Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CopilotReviewNote {
  id String @id @default(cuid())

  tradingAccountId String
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  tradeId String?

  title   String
  content String

  severity String

  createdAt DateTime @default(now())
}

model TradingSession {
  id String @id @default(cuid())

  tradingAccountId String
  createdById      String

  tradingAccount TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)
  createdBy      User           @relation(fields: [createdById], references: [id], onDelete: Cascade)

  date DateTime

  title          String?
  marketBias     String?
  focus          String?
  emotionalState String?
  sessionType    String?

  checklist       String?
  goals           String?
  mistakesToAvoid String?

  sessionReview String?
  finalScore    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TradingGoal {
  id String @id @default(cuid())

  tradingAccountId String
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  month Int
  year  Int

  monthlyProfitGoal  Float?
  monthlyWinRateGoal Float?
  maxDrawdownLimit   Float?
  maxTradesPerDay    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tradingAccountId, month, year])
}

model ActivityLog {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  accountId String?
  account   TradingAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  type        String
  title       String
  description String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([accountId])
  @@index([createdAt])
}

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type String

  title   String
  message String

  read Boolean @default(false)

  link String?

  createdAt DateTime @default(now())

  syncOperationEffect SyncOperationEffect?

  @@index([userId])
  @@index([read])
}

model PushSubscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint String @unique
  p256dh   String
  auth     String

  deviceLabel String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model TwoFactorCode {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  preAuthToken String   @unique
  codeHash     String
  expiresAt    DateTime
  attempts     Int      @default(0)
  used         Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([preAuthToken])
  @@index([expiresAt])
}

enum AccountType {
  DEMO
  LIVE
  PROP
  SHARED
  CHALLENGE
  FUNDED
}

enum AccountStatus {
  ACTIVE
  ARCHIVED
}

enum MemberRole {
  MANAGER
  MEMBER
  VIEWER
}
