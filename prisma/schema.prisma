generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String

  role String @default("MEMBER")

  status      String   @default("ACTIVE")
  frozenAt    DateTime?

  lastSeenAt DateTime?

  name              String?
  image             String?
  bio               String?
  workspaceName     String?
  
  tradingStyle      String?
  favoriteMarket    String?
  timezone          String?

  preferredSession  String?
  riskPerTrade      Float?
  preferredBroker   String?
  setupStyle        String?

  defaultCurrency    String   @default("USD")
  compactMode        Boolean  @default(false)
  performanceBlur    Boolean  @default(false)
  emailNotifications Boolean  @default(false)

  reviewReminders       Boolean @default(true)
  sessionLockAlerts     Boolean @default(true)
  dailyTradingReminder  Boolean @default(false)

  memberships   AccountMember[]
  createdTrades Trade[]
  createdSessions TradingSession[]

  supportTickets SupportTicket[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TradingAccount {
  id             String   @id @default(cuid())
  name           String
  type           AccountType
  status         AccountStatus @default(ACTIVE)

  initialBalance Float
  currency       String   @default("USD")

  broker          String?
  phase           String?
  profitTarget    Float?
  maxDrawdown     Float?
  dailyDrawdown   Float?

  members        AccountMember[]
  trades         Trade[]
  sessions       TradingSession[]
  goals          TradingGoal[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  copilotMessages CopilotMessage[]
  copilotPatterns CopilotPattern[]
  copilotReviewNotes CopilotReviewNote[]
  copilotMemories CopilotMemory[]
}

model AccountMember {
  id               String @id @default(cuid())
  userId           String
  tradingAccountId String
  role             MemberRole @default(MEMBER)

  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())

  @@unique([userId, tradingAccountId])
}

model Trade {
  id               Int      @id @default(autoincrement())

  tradingAccountId String
  createdById      String

  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)
  createdBy        User           @relation(fields: [createdById], references: [id], onDelete: Cascade)

  openDate         DateTime
  openTime         String?
  reason           String?
  strategy         String?
  symbol           String
  direction        String
  amount           Float?
  openingPrice     Float?
  stopLoss         Float?
  takeProfit       Float?
  riskReward       Float?
  closeDate        DateTime?
  closingPrice     Float?
  outcome          String?
  resultUsd        Float?
  resultPercent    Float?
  equity           Float?
  equityPeak       Float?
  drawdownPercent  Float?
  notes            String?

  session          String?
  emotionalState   String?
  setupQuality     Int?
  executionRating  Int?
  confidence       Int?
  mistakes         String?
  lessonsLearned   String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CopilotMessage {
  id               String   @id @default(cuid())

  tradingAccountId String
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  role             String
  content          String

  createdAt        DateTime @default(now())
}

model CopilotPattern {
  id               String   @id @default(cuid())

  tradingAccountId String
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  type             String
  title            String
  description      String
  severity         String

  occurrences      Int      @default(1)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CopilotMemory {
  id               String   @id @default(cuid())

  tradingAccountId String
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  memoryType       String
  title            String
  description      String

  severity         String
  score            Int

  firstDetectedAt  DateTime @default(now())
  lastDetectedAt   DateTime @updatedAt

  createdAt        DateTime @default(now())

  @@index([tradingAccountId])
}

model SupportTicket {
  id          String   @id @default(cuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String
  subject     String
  message     String

  status      String   @default("open")
  priority    String   @default("normal")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  adminNote   String?
  resolvedAt  DateTime?

  @@index([userId])
}

model ReleaseNote {
  id          String   @id @default(cuid())

  title       String
  content     String
  type        String   @default("update")
  priority    String   @default("normal")

  published   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MaintenanceMode {
  id            String   @id @default(cuid())

  enabled       Boolean  @default(false)

  title         String
  message       String

  type          String   @default("warning")

  startAt       DateTime?
  expectedEndAt DateTime?

  blockLogin    Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CopilotReviewNote {
  id               String   @id @default(cuid())

  tradingAccountId String
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  tradeId          String?

  title            String
  content          String

  severity         String

  createdAt        DateTime @default(now())
}

model TradingSession {
  id               String   @id @default(cuid())

  tradingAccountId String
  createdById      String

  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)
  createdBy        User           @relation(fields: [createdById], references: [id], onDelete: Cascade)

  date             DateTime

  title            String?
  marketBias       String?
  focus            String?
  emotionalState   String?
  sessionType      String?

  checklist        String?
  goals            String?
  mistakesToAvoid  String?

  sessionReview    String?
  finalScore       Int?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TradingGoal {
  id               String   @id @default(cuid())

  tradingAccountId String
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  month            Int
  year             Int

  monthlyProfitGoal Float?
  monthlyWinRateGoal Float?
  maxDrawdownLimit Float?
  maxTradesPerDay Int?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tradingAccountId, month, year])
}

enum AccountType {
  DEMO
  LIVE
  PROP
  SHARED
  CHALLENGE
  FUNDED
}

enum AccountStatus {
  ACTIVE
  ARCHIVED
}

enum MemberRole {
  OWNER
  MEMBER
  VIEWER
}